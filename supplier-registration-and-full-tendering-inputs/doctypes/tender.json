{
  "doctype": "DocType",
  "name": "Tender",
  "module": "KenTender Phase 2",
  "custom": 0,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "engine": "InnoDB",
  "field_order": [
    "tender_number",
    "entity",
    "title",
    "procurement_type",
    "method",
    "requisition_source_mode",
    "estimated_value",
    "currency",
    "advertisement_date",
    "closing_datetime",
    "opening_datetime",
    "submission_mode",
    "evaluation_method",
    "tender_status",
    "security_required",
    "security_amount",
    "clarification_deadline",
    "site_visit_required",
    "prebid_required",
    "prebid_datetime",
    "linked_requisition_count",
    "remarks"
