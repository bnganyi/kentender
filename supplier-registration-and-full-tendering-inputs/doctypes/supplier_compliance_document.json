{
  "doctype": "DocType",
  "name": "Supplier Compliance Document",
  "module": "KenTender Phase 2",
  "custom": 0,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "engine": "InnoDB",
  "field_order": [
    "supplier",
    "application",
    "document_type",
    "document_number",
    "issue_date",
    "expiry_date",
    "attachment",
    "verification_status",
    "verified_by",
    "verified_on",
    "remarks"
  ],
  "fields": [
    {
      "fieldname": "supplier",
      "label": "Supplier",
      "fieldtype": "Link",
      "options": "Supplier Master",
      "in_list_view": 1
    },
    {
      "fieldname": "application",
      "label": "Application",
      "fieldtype": "Link",
      "options": "Supplier Registration Application"
    },
    {
      "fieldname": "document_type",
      "label": "Document Type",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "Certificate of Incorporation\nTax Compliance\nVAT Certificate\nBusiness Permit\nCR12 / Shareholding\nProfessional License\nAudited Statements\nAGPO / Reserved Group Certificate\nOther",
      "in_list_view": 1
    },
    {
      "fieldname": "document_number",
      "label": "Document Number",
      "fieldtype": "Data"
    },
    {
      "fieldname": "issue_date",
      "label": "Issue Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "expiry_date",
      "label": "Expiry Date",
      "fieldtype": "Date",
      "in_list_view": 1
    },
    {
      "fieldname": "attachment",
      "label": "Attachment",
      "fieldtype": "Attach"
    },
    {
      "fieldname": "verification_status",
      "label": "Verification Status",
      "fieldtype": "Select",
      "reqd": 1,
      "options": "Pending\nVerified\nRejected\nExpired",
      "in_list_view": 1
    },
    {
      "fieldname": "verified_by",
      "label": "Verified By",
      "fieldtype": "Link",
      "options": "User"
    },
    {
      "fieldname": "verified_on",
      "label": "Verified On",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "remarks",
      "label": "Remarks",
      "fieldtype": "Small Text"
    }
  ],
  "permissions": []
}