    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "options": "Project",
      "label": "Project"
    },
    {
      "fieldname": "task",
      "fieldtype": "Link",
      "options": "Task",
      "label": "Task"
    },
    {
      "fieldname": "quality_inspection",
      "fieldtype": "Link",
      "options": "Quality Inspection",
      "label": "Quality Inspection"
    },
    {
      "fieldname": "purchase_receipt",
      "fieldtype": "Link",
      "options": "Purchase Receipt",
