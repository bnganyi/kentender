{
  "doctype": "DocType",
  "name": "Contract Variation",
  "module": "KenTender",
  "custom": 0,
  "istable": 0,
  "is_submittable": 1,
  "autoname": "format:CV-{YYYY}-{#####}",
  "fields": [
    {
      "fieldname": "contract",
      "fieldtype": "Link",
      "options": "Contract",
      "label": "Contract",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "variation_type",
      "fieldtype": "Select",
      "options": "Scope Change\nTime Extension\nCost Adjustment",
      "label": "Variation Type",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "justification",
      "fieldtype": "Small Text",
      "label": "Justification",
      "reqd": 1
    },
    {
      "fieldname": "financial_impact",
      "fieldtype": "Currency",
      "label": "Financial Impact"
    },
    {
      "fieldname": "time_extension_days",
      "fieldtype": "Int",
      "label": "Time Extension (Days)"
    },
    {
      "fieldname": "revised_contract_value",
      "fieldtype": "Currency",
      "label": "Revised Contract Value"
    },
    {
      "fieldname": "revised_end_date",
      "fieldtype": "Date",
      "label": "Revised End Date"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Draft\nUnder Review\nApproved\nRejected\nImplemented",
      "label": "Status",
      "default": "Draft",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "approved_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Approved By"
    },
    {
      "fieldname": "approved_on",
      "fieldtype": "Datetime",
      "label": "Approved On"
    }
    ,
    {
      "fieldname": "second_level_approved",
      "fieldtype": "Check",
      "label": "Second Level Approved",
      "default": 0
    },
    {
      "fieldname": "second_level_approved_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Second Level Approved By"
    },
    {
      "fieldname": "second_level_approved_on",
      "fieldtype": "Datetime",
      "label": "Second Level Approved On"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Head of Procurement",
      "create": 1,
      "read": 1,
      "write": 1,
      "submit": 1
    },
    {
      "role": "Accounting Officer",
      "read": 1,
      "write": 1,
      "submit": 1
    },
    {
      "role": "Head of Finance",
      "read": 1
    }
  ]
}

