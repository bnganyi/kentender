    {"fieldname": "risk_level", "fieldtype": "Select", "label": "Risk Level", "options": "Low\nMedium\nHigh", "default": "Medium"},
    {"fieldname": "requested_by", "fieldtype": "Link", "label": "Requested By", "options": "User", "reqd": 1},
    {"fieldname": "reviewed_by", "fieldtype": "Link", "label": "Reviewed By", "options": "User"},
    {"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nUnder Review\nApproved\nRejected\nClosed", "default": "Draft"},
