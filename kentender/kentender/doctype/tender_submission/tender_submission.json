{
  "doctype": "DocType",
  "name": "Tender Submission",
  "module": "KenTender",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:TS-{YYYY}-{#####}",
  "fields": [
    {
      "fieldname": "tender",
      "label": "Tender",
      "fieldtype": "Link",
      "options": "Tender",
      "reqd": 1
    },
    {
      "fieldname": "supplier",
      "label": "Supplier",
      "fieldtype": "Link",
      "options": "Supplier",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "currency",
      "label": "Currency",
      "fieldtype": "Link",
      "options": "Currency",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "quoted_amount",
      "label": "Quoted Amount",
      "fieldtype": "Currency",
      "options": "currency",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "exchange_rate",
      "label": "Exchange Rate",
      "fieldtype": "Float",
      "in_list_view": 1
    },
    {
      "fieldname": "base_amount",
      "label": "Base Amount",
      "fieldtype": "Currency",
      "options": "currency",
      "in_list_view": 1
    },
    {
      "fieldname": "scores",
      "label": "Scores",
      "fieldtype": "Table",
      "options": "Submission Scores",
      "in_list_view": 0
    },
    {
      "fieldname": "submission_status",
      "label": "Submission Status",
      "fieldtype": "Select",
      "options": "Draft\nSubmitted\nLocked\nWithdrawn\nReplaced\nLate\nOpened\nEvaluated\nNon-Responsive\nResponsive",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "submitted_on",
      "label": "Submitted On",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "server_received_on",
      "label": "Server Received On",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "withdrawn_on",
      "label": "Withdrawn On",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "replacement_of_submission",
      "label": "Replacement Of Submission",
      "fieldtype": "Link",
      "options": "Tender Submission"
    },
    {
      "fieldname": "security_provided",
      "label": "Security Provided",
      "fieldtype": "Check"
    },
    {
      "fieldname": "security_reference",
      "label": "Security Reference",
      "fieldtype": "Data"
    },
    {
      "fieldname": "read_only_after_deadline",
      "label": "Read Only After Deadline",
      "fieldtype": "Check",
      "default": "0"
    },
    {
      "fieldname": "sealed_flag",
      "label": "Sealed Flag",
      "fieldtype": "Check",
      "default": "1"
    },
    {
      "fieldname": "total_score",
      "label": "Total Score",
      "fieldtype": "Float",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 1
    },
    {
      "role": "Supplier",
      "create": 1,
      "read": 1,
      "write": 1
    },
    {
      "role": "Procurement User",
      "read": 1
    },
    {
      "role": "Procurement Manager",
      "read": 1
    }
  ]
}
