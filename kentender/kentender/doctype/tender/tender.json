{
  "doctype": "DocType",
  "name": "Tender",
  "module": "KenTender",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:TN-{YYYY}-{#####}",
  "fields": [
    {
      "fieldname": "company",
      "label": "Company",
      "fieldtype": "Link",
      "options": "Company",
      "reqd": 1
    },
    {
      "fieldname": "procurement_plan_item",
      "label": "Procurement Plan Item",
      "fieldtype": "Link",
      "options": "Procurement Plan Item",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Draft\nInternal Review\nApproved for Publication\nPublished\nClosed\nOpened\nUnder Evaluation\nAward Recommended\nAward Approved\nAward Published\nEvaluated\nAwarded\nCancelled",
      "default": "Draft"
    },
    {
      "fieldname": "method",
      "label": "Method",
      "fieldtype": "Select",
      "options": "Open Tender\nRestricted Tender\nRFQ\nRFP\nDirect Procurement"
    },
    {
      "fieldname": "procurement_type",
      "label": "Procurement Type",
      "fieldtype": "Select",
      "options": "Goods\nWorks\nNon-Consulting Services\nConsulting Services\nAsset Disposal"
    },
    {
      "fieldname": "evaluation_method",
      "label": "Evaluation Method",
      "fieldtype": "Select",
      "options": "Pass-Fail\nWeighted Score\nLeast Evaluated Cost\nQCBS\nOther"
    },
    {
      "fieldname": "publish_date",
      "label": "Publish Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "submission_deadline",
      "label": "Submission Deadline",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "closing_datetime",
      "label": "Closing Datetime",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "opening_datetime",
      "label": "Opening Datetime",
      "fieldtype": "Datetime"
    },
    {
      "fieldname": "linked_requisition_count",
      "label": "Linked Requisition Count",
      "fieldtype": "Int",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "security_required",
      "label": "Security Required",
      "fieldtype": "Check"
    },
    {
      "fieldname": "security_amount",
      "label": "Security Amount",
      "fieldtype": "Currency"
    },
    {
      "fieldname": "challenge_hold",
      "label": "Challenge Hold",
      "fieldtype": "Check",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "purchase_order",
      "label": "Purchase Order",
      "fieldtype": "Link",
      "options": "Purchase Order"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 1
    },
    {
      "role": "Procurement User",
      "create": 1,
      "read": 1,
      "write": 1
    },
    {
      "role": "Procurement Manager",
      "read": 1,
      "write": 1
    }
  ]
}
