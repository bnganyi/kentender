{
  "doctype": "DocType",
  "name": "Defect Liability Case",
  "module": "KenTender",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:DLC-{YYYY}-{#####}",
  "fields": [
    {
      "fieldname": "contract",
      "fieldtype": "Link",
      "options": "Contract",
      "label": "Contract",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "options": "Project",
      "label": "Project",
      "in_list_view": 1
    },
    {
      "fieldname": "reported_on",
      "fieldtype": "Datetime",
      "label": "Reported On",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reported_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Reported By"
    },
    {
      "fieldname": "defect_description",
      "fieldtype": "Small Text",
      "label": "Defect Description",
      "reqd": 1
    },
    {
      "fieldname": "severity",
      "fieldtype": "Select",
      "options": "Low\nMedium\nHigh\nCritical",
      "label": "Severity",
      "default": "Medium",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Open\nUnder Review\nAssigned\nResolved\nClosed",
      "label": "Status",
      "default": "Open",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "resolution_due_date",
      "fieldtype": "Date",
      "label": "Resolution Due Date"
    },
    {
      "fieldname": "resolved_on",
      "fieldtype": "Datetime",
      "label": "Resolved On"
    },
    {
      "fieldname": "contract_reopened",
      "fieldtype": "Check",
      "label": "Contract Reopened"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 1
    },
    {
      "role": "Head of Procurement",
      "create": 1,
      "read": 1,
      "write": 1
    },
    {
      "role": "Contract Implementation Team",
      "create": 1,
      "read": 1,
      "write": 1
    },
    {
      "role": "Inspection and Acceptance Committee",
      "read": 1
    }
  ]
}

