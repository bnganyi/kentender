{
  "doctype": "DocType",
  "name": "National Development Plan",
  "module": "KenTender",
  "custom": 1,
  "track_changes": 1,
  "autoname": "field:plan_code",
  "fields": [
    {
      "fieldname": "plan_name",
      "label": "Plan Name",
      "fieldtype": "Data",
      "reqd": 1
    },
    {
      "fieldname": "plan_code",
      "label": "Plan Code",
      "fieldtype": "Data",
      "reqd": 1,
      "unique": 1
    },
    {
      "fieldname": "country",
      "label": "Country",
      "fieldtype": "Data",
      "default": "Kenya",
      "reqd": 1
    },
    {
      "fieldname": "start_year",
      "label": "Start Year",
      "fieldtype": "Int",
      "reqd": 1
    },
    {
      "fieldname": "end_year",
      "label": "End Year",
      "fieldtype": "Int",
      "reqd": 1
    },
    {
      "fieldname": "approval_authority",
      "label": "Approval Authority",
      "fieldtype": "Data",
      "reqd": 1
    },
    {
      "fieldname": "approval_date",
      "label": "Approval Date",
      "fieldtype": "Date",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Draft\nApproved\nActive\nArchived",
      "default": "Draft",
      "reqd": 1
    },
    {
      "fieldname": "document_reference",
      "label": "Document Reference",
      "fieldtype": "Attach"
    },
    {
      "fieldname": "description",
      "label": "Description",
      "fieldtype": "Long Text"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 1
    },
    {
      "role": "Procurement Manager",
      "create": 1,
      "read": 1,
      "write": 1,
      "delete": 0
    }
  ]
}

